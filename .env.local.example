# Local host deployment example for a Linux Mint machine that should behave
# similarly to the current working host. Copy to `.env.local` and replace
# placeholder values with host-specific secrets.

# --- Core gateway ---
GOCLAW_GATEWAY_TOKEN=replace-with-random-token
GOCLAW_ENCRYPTION_KEY=replace-with-64-char-hex-key
GOCLAW_OWNER_IDS=system

# --- Database ---
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_PORT=5433
GOCLAW_POSTGRES_DSN=postgres://goclaw:replace-with-db-password@localhost:5433/goclaw?sslmode=disable

# --- Browser / PinchTab ---
GOCLAW_BROWSER_PINCHTAB_URL=http://localhost:9867
GOCLAW_BROWSER_PINCHTAB_TOKEN=replace-with-pinchtab-token
GOCLAW_BROWSER_PINCHTAB_MODE=headed
GOCLAW_BROWSER_PINCHTAB_PROFILE=goclaw

# --- Proxy path (match the current host if needed) ---
HTTP_PROXY=http://100.66.97.93:8888
HTTPS_PROXY=http://100.66.97.93:8888
NO_PROXY=localhost,127.0.0.1,100.113.140.25,100.66.97.93,100.100.74.9,::1

# --- Debug / tracing ---
GOCLAW_TRACE_VERBOSE=1

# --- Optional local integrations ---
# DOCKER_GID=103
# CODE_PROXY_API_KEY=replace-with-code-proxy-key
# N8N_BASE_URL=https://example.com
# N8N_API_KEY=replace-with-n8n-api-key
